<div{{ attributes }}>
  {{ title_prefix }}
  {% if label %}
  <h2{{ title_attributes }}>{{ label }}</h2>
    {% endif %}
    {{ title_suffix }}
    {% block content %}
    <div class="footer-brand">
      <div class="d-flex align-items-center gap-2 mb-3">
        <div class="brand-icon" style="width: 38px; height: 38px; font-size: 17px">
          M
        </div>
        <div>
          <div class="name">{{content.field_title | render|striptags  }}</div>
          <div class="tag">{{content.field_sub_title| render|striptags}}</div>
        </div>
      </div>
    </div>
    <p>
 {{content.body| render|striptags }}
    </p>



    <div class="d-flex gap-2 flex-wrap">
      <span style="
              background: rgba(255, 255, 255, 0.07);
              color: #adc8e8;
              padding: 5px 12px;
              border-radius: 100px;
              font-size: 12px;
              font-weight: 700;
            "><i class="fa fa-shield-halved me-1"></i>{{ content.field_tag_1| render|striptags}}</span>
      <span style="
              background: rgba(255, 255, 255, 0.07);
              color: #adc8e8;
              padding: 5px 12px;
              border-radius: 100px;
              font-size: 12px;
              font-weight: 700;
            "><i class="fa fa-star me-1"></i> {{ content.field_tag_2| render|striptags }}</span>
    </div>

    {% endblock %}
    </div>