    </div>
    <div class="contact-card" data-aos="fade-up" data-aos-delay="100">
      <div class="row g-0">
        <div class="col-lg-4">
          <div class="contact-info">
            <h3>Let's Connect</h3>
            <p>We're here to assist you with all your financial, property, vehicle, and travel requirements. Reach out to us anytime.</p>
            <div class="ci-item">
              <div class="ci-icon"><i class="fa fa-location-dot"></i></div>
              <div>
                <h6>OUR ADDRESS</h6>
                <p>123, Manglam House, Main Market Road, Jaipur, Rajasthan – 302001</p>
              </div>
            </div>
            <div class="ci-item">
              <div class="ci-icon"><i class="fa fa-phone"></i></div>
              <div>
                <h6>PHONE NUMBER</h6>
                <p>+91 99999 99999</p>
              </div>
            </div>
            <div class="ci-item">
              <div class="ci-icon"><i class="fa fa-envelope"></i></div>
              <div>
                <h6>EMAIL ADDRESS</h6>
                <p>info@manglamgroup.in</p>
              </div>
            </div>
            <div class="ci-item">
              <div class="ci-icon"><i class="fa fa-clock"></i></div>
              <div>
                <h6>WORKING HOURS</h6>
                <p>Mon–Sat: 9:00 AM – 7:00 PM</p>
              </div>
            </div>
            <div class="social-links">
              <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
              <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
              <a href="#" class="social-link"><i class="fab fa-linkedin-in"></i></a>
              <a href="https://wa.me/919999999999" class="social-link"><i class="fab fa-whatsapp"></i></a>
            </div>
          </div>
        </div>
        <div class="col-lg-8">
          <div class="contact-form">
            <h3>Send Us a Message</h3>
            <p class="sub">Our expert team will respond within 30 minutes during business hours.</p>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name *</label>
                <input type="text" class="form-control" placeholder="Enter your full name">
              </div>
              <div class="col-md-6">
                <label class="form-label">Mobile Number *</label>
                <input type="tel" class="form-control" placeholder="+91 XXXXX XXXXX">
              </div>
              <div class="col-md-6">
                <label class="form-label">Email Address</label>
                <input type="email" class="form-control" placeholder="your@email.com">
              </div>
              <div class="col-md-6">
                <label class="form-label">Service Required *</label>
                <select class="form-select">
                  <option>Select Service</option>
                  <option>Loan Services</option>
                  <option>Property Services</option>
                  <option>Vehicle Buy / Sell</option>
                  <option>Travel & Transport</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label">Message</label>
                <textarea class="form-control" rows="4" placeholder="Tell us about your requirement in detail..."></textarea>
              </div>
              <div class="col-12">
                <button class="btn-submit">
                  <i class="fa fa-paper-plane me-2"></i> Request Callback
                </button>
              </div>
            </div>
          </div>
        </div>
