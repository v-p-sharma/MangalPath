<!-- ELIGIBILITY & CRITERIA -->
<section class="py-section" style="background:var(--white);">
  <div class="container">
    <div class="row g-4">
      <!-- Eligibility -->
      <div class="col-lg-6">
        <h3 class="mb-4" style="font-family:'Playfair Display', serif; color:var(--primary-dark);">Who is Eligible?</h3>
        <div class="eligibility-card">
          <h4><i class="fa fa-user-tie text-primary"></i> Salaried Individuals</h4>
          <ul class="check-list">
            <li><i class="fa fa-circle-check"></i> Age: 21 to 58 years</li>
            <li><i class="fa fa-circle-check"></i> Minimum net monthly income: ₹25,000</li>
            <li><i class="fa fa-circle-check"></i> Stable employment for at least 1 year</li>
            <li><i class="fa fa-circle-check"></i> Resident Indian citizen</li>
          </ul>
          <h4 class="mt-4"><i class="fa fa-briefcase text-primary"></i> Self-Employed</h4>
          <ul class="check-list">
            <li><i class="fa fa-circle-check"></i> Age: 23 to 58 years</li>
            <li><i class="fa fa-circle-check"></i> Business vintage: Minimum 3 years</li>
            <li><i class="fa fa-circle-check"></i> Turnover as per requirement</li>
            <li><i class="fa fa-circle-check"></i> Filing IT Returns regularly</li>
          </ul>
        </div>
      </div>

      <!-- Criteria / Documents -->
      <div class="col-lg-6">
        <h3 class="mb-4" style="font-family:'Playfair Display', serif; color:var(--primary-dark);">Documents Required</h3>
        <div class="eligibility-card">
          <h4><i class="fa fa-file-contract text-primary"></i> KYC Documents</h4>
          <ul class="check-list">
            <li><i class="fa fa-file-arrow-down"></i> PAN Card (Mandatory)</li>
            <li><i class="fa fa-file-arrow-down"></i> Aadhar Card / Voter ID</li>
            <li><i class="fa fa-file-arrow-down"></i> Passport Size Photographs</li>
          </ul>
          <h4 class="mt-4"><i class="fa fa-wallet text-primary"></i> Income Proof</h4>
          <ul class="check-list">
            <li><i class="fa fa-file-arrow-down"></i> Last 3 months Salary Slips</li>
            <li><i class="fa fa-file-arrow-down"></i> Form 16 or Last 2 years ITR</li>
            <li><i class="fa fa-file-arrow-down"></i> Last 6 months Bank Statement</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>