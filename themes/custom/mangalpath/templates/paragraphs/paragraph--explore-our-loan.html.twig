<section class="py-section">
  <div class="container">
  
    <h2 class="section-title">{{paragraph.field_title_full[0].value|raw}}</h2>
    <p class="section-sub">{{paragraph.field_description[0].value|raw}}</p>
    
    <div class="row g-4">
      <!-- Home Loan -->
       {%for items in paragraph.field_loan_inner %}
         <div class="col-md-6 col-lg-3">
        <div class="loan-card">
          <div class="loan-icon"><i class="{{items.entity.field_icon_class[0].value}}"></i></div>
          <h4>{{items.entity.field_title[0].value}}</h4>
          <p style="font-size:13px; color:var(--text-muted);">{{items.entity.field_description[0].value}}</p>
          <ul class="loan-features">
            {%for innerItems in items.entity.field_list %}
             
           <li><i class="fa fa-check"></i> {{innerItems.entity.field_titles[0].value}}</li>
            {% endfor %}
 
          </ul>
          <a href="{{items.entity.field_know_more[0].url.toString()}}" class="btn-check-eligibility">{{items.entity.field_know_more[0].title}}</a>
        </div>
      </div>

       {% endfor %}
  
    </div>
  </div>
</section>

