<section class="py-section" style="background:var(--light-bg);">
  <div class="container">
    <h2 class="section-title">{{paragraph.field_title_full[0].value|raw}}</h2>
    <p class="section-sub">{{paragraph.field_description[0].value|striptags}}</p>
    
    <div class="row g-4">
      {%for items in paragraph.field_why_choose_loan_inner %}

      <div class="col-md-6 col-lg-3">
        <div class="property-trust-item">
          <div class="trust-icon"><i class="{{items.entity.field_icon_class[0].value}}"></i></div>
          <h5 style="font-weight:800; margin-bottom:10px;">{{items.entity.field_title[0].value}}</h5>
          <p style="font-size:13px; color:var(--text-muted);">{{items.entity.field_description[0].value}}</p>
        </div>
      </div>
        
      {% endfor %}
    
    </div>
  </div>
</section>