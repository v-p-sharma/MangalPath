<section class="why-section" id="about">
  <div class="container">
    <div class="text-center mb-5" data-aos="fade-up">
      <div class="section-badge">{{paragraph.field_sub_title[0].value }}</div>
      <h2 class="section-title">{{paragraph.field_title_full[0].value |raw }}</span></h2>
      <div class="section-line center"></div>
      <p class="section-sub mt-3">{{paragraph.field_description[0].value|striptags}}</p>
    </div>
    <div class="row g-4">
      {% for items in paragraph.field_why_we_choose_inner_conne  %}
               <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="0">
        <div class="why-card">
          <div class="why-icon" style="background:#e3edf8; color:var(--primary)"><i class="{{items.entity.field_icon_class[0].value}}"></i></div>
          <h5>{{items.entity.field_title[0].value}}</h5>
          <p>{{items.entity.field_description[0].value}}</p>
        </div>
      </div> 
      {% endfor %}
    </div>
  </div>
</section>