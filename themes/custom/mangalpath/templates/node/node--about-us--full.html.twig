        .team-body p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0;}

        /* ===== TIMELINE ===== */
        .timeline-section{padding:80px 0;background:var(--light-bg);}
        .timeline{position:relative;max-width:800px;margin:0 auto;}
        .timeline::before{content:'';position:absolute;left:50%;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--primary),var(--accent),var(--green));transform:translateX(-50%);border-radius:2px;}
        .tl-item{position:relative;width:50%;padding:0 40px 40px;}
        .tl-item:nth-child(odd){left:0;text-align:right;padding-right:50px;padding-left:0;}
        .tl-item:nth-child(even){left:50%;text-align:left;padding-left:50px;padding-right:0;}
        .tl-dot{position:absolute;width:18px;height:18px;border-radius:50%;background:var(--accent);border:3px solid white;box-shadow:0 0 0 3px var(--accent),0 4px 12px rgba(245,130,31,0.3);top:4px;z-index:1;}
        .tl-item:nth-child(odd) .tl-dot{right:-9px;}
        .tl-item:nth-child(even) .tl-dot{left:-9px;}
        .tl-year{display:inline-block;font-size:12px;font-weight:800;color:var(--accent);background:rgba(245,130,31,0.1);padding:3px 12px;border-radius:100px;margin-bottom:8px;}
        .tl-content{background:white;border-radius:12px;padding:20px;box-shadow:0 4px 20px rgba(26,60,110,0.08);border:1.5px solid var(--border);transition:all .3s;}
        .tl-content:hover{box-shadow:0 8px 30px rgba(26,60,110,0.12);transform:translateY(-3px);}
        .tl-content h5{font-size:15px;font-weight:800;color:var(--primary-dark);margin-bottom:6px;}
        .tl-content p{font-size:13px;color:var(--text-muted);line-height:1.6;margin:0;}
        @media(max-width:767px){
            .timeline::before{left:20px;}
            .tl-item{width:100%;left:0!important;text-align:left!important;padding-left:50px!important;padding-right:0!important;}
            .tl-item .tl-dot{left:11px!important;right:auto!important;}
        }

        /* ===== TESTIMONIALS ===== */
        .testimonials-section{padding:80px 0;background:var(--white);}
        .testi-card{background:white;border-radius:var(--radius);padding:28px;box-shadow:var(--card-shadow);border:1.5px solid var(--border);transition:all .3s;height:100%;}
        .testi-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(26,60,110,0.13);border-color:var(--accent);}
        .testi-header{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
        .testi-avatar{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:white;flex-shrink:0;}
        .testi-name{font-size:15px;font-weight:800;color:var(--primary-dark);}
        .testi-service{font-size:11.5px;font-weight:700;color:var(--accent);background:rgba(245,130,31,0.1);padding:2px 8px;border-radius:100px;display:inline-block;margin-top:3px;}
        .testi-stars{color:#f59e0b;font-size:13px;margin-bottom:10px;letter-spacing:1px;}
