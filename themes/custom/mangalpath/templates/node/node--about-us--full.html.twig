        .story-text p{margin-bottom:16px;}
        .story-highlight{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:white;border-radius:var(--radius);padding:32px;position:relative;overflow:hidden;}
        .story-highlight::before{content:'';position:absolute;top:-30px;right:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;}
        .story-highlight p{font-size:18px;font-weight:700;line-height:1.7;margin:0;opacity:.95;}
        .story-highlight p span{color:var(--accent);font-weight:900;}
        .story-image{width:100%;border-radius:var(--radius);object-fit:cover;aspect-ratio:4/3;box-shadow:var(--card-shadow);}

        /* ===== MISSION VISION ===== */
        .mv-section{padding:80px 0;background:var(--light-bg);}
        .mv-card{background:white;border-radius:var(--radius);padding:32px;box-shadow:var(--card-shadow);border:1.5px solid transparent;height:100%;transition:all .3s;position:relative;overflow:hidden;}
        .mv-card:hover{transform:translateY(-6px);border-color:var(--accent);box-shadow:0 12px 40px rgba(26,60,110,0.13);}
        .mv-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;}
        .mv-card.mission::before{background:linear-gradient(90deg,var(--primary),var(--accent));}
        .mv-card.vision::before{background:linear-gradient(90deg,var(--accent),var(--green));}
        .mv-icon{width:64px;height:64px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:20px;}
        .mv-card.mission .mv-icon{background:#e3edf8;color:var(--primary);}
        .mv-card.vision .mv-icon{background:#fff3e0;color:var(--accent);}
        .mv-card h3{font-family:'Playfair Display',serif;font-size:24px;font-weight:800;color:var(--primary-dark);margin-bottom:12px;}
        .mv-card p{font-size:14px;color:var(--text-muted);line-height:1.8;margin:0;}

        /* ===== VALUES ===== */
        .values-section{padding:80px 0;background:var(--white);}
        .value-card{background:white;border-radius:var(--radius);padding:28px 24px;box-shadow:var(--card-shadow);transition:all .3s;border:1.5px solid transparent;height:100%;text-align:center;}
        .value-card:hover{transform:translateY(-6px);border-color:var(--accent);box-shadow:0 12px 40px rgba(26,60,110,0.13);}
        .value-icon{width:72px;height:72px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 18px;transition:transform .3s;}
        .value-card:hover .value-icon{transform:scale(1.08);}
        .value-card h5{font-size:17px;font-weight:800;color:var(--primary-dark);margin-bottom:10px;}
        .value-card p{font-size:13.5px;color:var(--text-muted);line-height:1.7;margin:0;}

        /* ===== STATS ===== */
        .stats-section{background:linear-gradient(135deg,var(--primary-dark) 0%,#1a4a8a 100%);padding:70px 0;position:relative;overflow:hidden;}
        .stats-section::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");}
        .stat-item{text-align:center;color:white;padding:10px;}
        .stat-number{font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,52px);font-weight:800;color:var(--accent);line-height:1;margin-bottom:6px;}
        .stat-label{font-size:14px;font-weight:700;opacity:.85;letter-spacing:.3px;}
        .stat-divider{width:40px;height:2px;background:rgba(255,255,255,0.2);margin:8px auto;}
        .stat-icon{font-size:28px;opacity:.3;margin-bottom:10px;}

        /* ===== SERVICES RECAP ===== */
        .services-recap{padding:80px 0;background:var(--light-bg);}
        .sr-card{background:white;border-radius:var(--radius);border:1.5px solid var(--border);overflow:hidden;box-shadow:var(--card-shadow);transition:all .3s;height:100%;display:flex;flex-direction:column;}
        .sr-card:hover{transform:translateY(-6px);box-shadow:0 16px 50px rgba(26,60,110,0.14);border-color:transparent;}
        .sr-card-header{padding:22px 22px 16px;display:flex;align-items:flex-start;gap:14px;}
        .sr-icon-wrap{width:54px;height:54px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
        .sr-card-header h4{font-size:17px;font-weight:900;margin-bottom:4px;}
        .sr-card-header p{font-size:12.5px;color:var(--text-muted);margin:0;line-height:1.5;}
        .sr-list{padding:0 22px 16px;flex:1;}
        .sr-list li{list-style:none;font-size:13px;font-weight:600;color:var(--text-muted);padding:5px 0;border-bottom:1px dashed var(--border);display:flex;align-items:center;gap:8px;}
        .sr-list li:last-child{border-bottom:none;}
        .sr-list li::before{content:'';width:7px;height:7px;border-radius:50%;flex-shrink:0;}
        .sr-card-footer{padding:16px 22px 22px;}
        .btn-know-more{font-weight:800;font-size:13px;padding:9px 22px;border-radius:8px;border:2px solid;transition:all .2s;display:inline-flex;align-items:center;gap:6px;text-decoration:none;background:transparent;cursor:pointer;font-family:'Nunito',sans-serif;}
        .btn-know-more:hover{transform:translateX(2px);}
        .theme-blue .sr-icon-wrap{background:#e3edf8;color:var(--primary);}
        .theme-blue .sr-card-header h4{color:var(--primary);}
        .theme-blue .sr-list li::before{background:var(--primary);}
        .theme-blue .btn-know-more{border-color:var(--primary);color:var(--primary);}
        .theme-blue .btn-know-more:hover{background:var(--primary);color:white;}
        .theme-orange .sr-icon-wrap{background:#fff3e0;color:var(--accent);}
        .theme-orange .sr-card-header h4{color:var(--accent);}
        .theme-orange .sr-list li::before{background:var(--accent);}
        .theme-orange .btn-know-more{border-color:var(--accent);color:var(--accent);}
        .theme-orange .btn-know-more:hover{background:var(--accent);color:white;}
        .theme-green .sr-icon-wrap{background:#e8f5e9;color:#1b8a3e;}
        .theme-green .sr-card-header h4{color:#1b8a3e;}
        .theme-green .sr-list li::before{background:#1b8a3e;}
        .theme-green .btn-know-more{border-color:#1b8a3e;color:#1b8a3e;}
        .theme-green .btn-know-more:hover{background:#1b8a3e;color:white;}
        .theme-purple .sr-icon-wrap{background:#f0ebff;color:#6d28d9;}
        .theme-purple .sr-card-header h4{color:#6d28d9;}
        .theme-purple .sr-list li::before{background:#6d28d9;}
        .theme-purple .btn-know-more{border-color:#6d28d9;color:#6d28d9;}
        .theme-purple .btn-know-more:hover{background:#6d28d9;color:white;}

        /* ===== TEAM ===== */
        .team-section{padding:80px 0;background:var(--white);}
        .team-card{background:white;border-radius:var(--radius);border:1.5px solid var(--border);overflow:hidden;box-shadow:var(--card-shadow);transition:all .3s;text-align:center;}
