        .hfc-icon.orange{background:#fff3e0;color:var(--accent);}
        .hfc-icon.blue{background:#e3edf8;color:var(--primary);}
        .hfc-icon.green{background:#e8f5e9;color:var(--green);}
        .hfc-val{font-size:20px;font-weight:900;color:var(--primary-dark);line-height:1.1;}
        .hfc-label{font-size:11px;color:var(--text-muted);font-weight:600;}

        /* ===== STORY ===== */
