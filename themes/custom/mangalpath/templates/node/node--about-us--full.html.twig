        .team-img-wrap{position:relative;overflow:hidden;aspect-ratio:1/1;background:var(--light-bg);}
        .team-img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
        .team-card:hover .team-img{transform:scale(1.05);}
        .team-social-overlay{position:absolute;bottom:0;left:0;right:0;padding:16px;display:flex;justify-content:center;gap:8px;transform:translateY(100%);transition:transform .3s;background:linear-gradient(transparent,rgba(15,37,72,0.7));}
        .team-card:hover .team-social-overlay{transform:translateY(0);}
        .team-social-btn{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.2);border:none;color:white;display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;transition:all .2s;text-decoration:none;backdrop-filter:blur(4px);}
        .team-social-btn:hover{background:var(--accent);transform:translateY(-2px);}
