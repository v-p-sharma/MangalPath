        .carousel-controls-wrap{display:flex;justify-content:center;gap:14px;margin-top:28px;}
        .carousel-indicators{position:static;margin:16px 0 0;}
        .carousel-indicators [data-bs-target]{width:10px;height:10px;border-radius:50%;background:var(--border);border:none;opacity:1;transition:all .2s;}
        .carousel-indicators .active{background:var(--primary);transform:scale(1.3);}

        /* ===== CTA ===== */
        .cta-section{background:linear-gradient(135deg,var(--accent) 0%,#e06010 100%);padding:70px 0;position:relative;overflow:hidden;text-align:center;color:white;}
        .cta-section::before{content:'';position:absolute;top:-80px;left:-80px;width:300px;height:300px;background:rgba(255,255,255,0.07);border-radius:50%;}
        .cta-section::after{content:'';position:absolute;bottom:-60px;right:-60px;width:250px;height:250px;background:rgba(255,255,255,0.07);border-radius:50%;}
        .cta-section h2{font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,42px);font-weight:800;margin-bottom:14px;}
        .cta-section p{font-size:15px;opacity:.9;max-width:600px;margin:0 auto 28px;line-height:1.7;}
        .btn-cta{background:white;color:var(--accent);font-weight:800;font-size:15px;padding:14px 32px;border-radius:10px;border:none;box-shadow:0 4px 20px rgba(0,0,0,0.2);transition:all .2s;text-decoration:none;display:inline-block;}
        .btn-cta:hover{transform:translateY(-2px);box-shadow:0 6px 28px rgba(0,0,0,0.25);color:var(--accent-dark);}
/* ===== FLOATING ===== */
        #backToTop{position:fixed;bottom:24px;right:24px;z-index:9999;width:44px;height:44px;border-radius:10px;background:var(--primary);color:white;border:none;font-size:17px;box-shadow:0 4px 14px rgba(26,60,110,0.35);opacity:0;pointer-events:none;transition:all .3s;cursor:pointer;}
        #backToTop.visible{opacity:1;pointer-events:auto;}
        #backToTop:hover{background:var(--accent);transform:translateY(-2px);}
        .wa-float{position:fixed;bottom:24px;left:24px;z-index:9999;width:52px;height:52px;border-radius:50%;background:#25d366;color:white;display:flex;align-items:center;justify-content:center;font-size:26px;box-shadow:0 4px 20px rgba(37,211,102,0.45);text-decoration:none;animation:waPulse 2.5s infinite;}
        @keyframes waPulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.45);}50%{box-shadow:0 4px 32px rgba(37,211,102,0.65);}}

        /* ===== RESPONSIVE ===== */
        @media(max-width:991px){
            .navbar-nav .nav-link{padding:12px 16px!important;}
            .navbar-nav .nav-link::after{display:none;}
            .footer-social{justify-content:flex-start;margin-top:12px;}
            .hero-float-card.card-a{left:10px;bottom:-10px;}
            .hero-float-card.card-b{right:10px;top:10px;}
        }
        @media(max-width:767px){
            .about-hero{padding:40px 0 80px;}
            .hero-float-card{display:none;}
            .story-section,.mv-section,.values-section,.services-recap,.team-section,.timeline-section,.testimonials-section{padding:60px 0;}
