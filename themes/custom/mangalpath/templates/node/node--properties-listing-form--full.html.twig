<section class="gallery-section">
    <div class="container">

        {% set featured_image = node.field_featured_image.entity %}
        {% set gallery_images = node.field_property_gallery %}
        {% set purpose = node.field_purpose_of.entity %}

        <div class="gallery-main-wrap" data-aos="fade-up">

            {% if featured_image %}
            <img src="{{ file_url(featured_image.uri.value) }}" alt="{{ node.label }}" class="gallery-main"
                id="mainImage" onclick="openLightbox(0)">
            {% endif %}

            <div class="gallery-badge-wrap">

                {% if purpose %}
                <span class="gallery-badge badge-sell">
                    <i class="fa fa-tag"></i>
                    {{ purpose.name.value }}
                </span>
                {% endif %}

                <span class="gallery-badge badge-featured">
                    <i class="fa fa-star"></i> Featured
                </span>

            </div>

            <div class="gallery-count" onclick="openLightbox(0)">
                <i class="fa fa-images me-1"></i>
                View All {{ gallery_images|length + (featured_image ? 1 : 0) }} Photos
            </div>

        </div>

        <div class="gallery-thumbs" data-aos="fade-up" data-aos-delay="100">

            {% if featured_image %}
            <img src="{{ file_url(featured_image.uri.value) }}" alt="{{ node.label }}" class="gallery-thumb active"
                onclick="changeImage(this, 0)">
            {% endif %}

            {% for item in gallery_images %}

            <img src="{{ file_url(item.entity.uri.value) }}" alt="{{ node.label }} {{ loop.index }}"
                class="gallery-thumb" onclick="changeImage(this, {{ loop.index }})">

            {% endfor %}

        </div>
    </div>
</section>

<!-- PROPERTY HEADER + PRICE SIDEBAR -->
<section class="prop-header">
    <div class="container">
        <div class="row g-4">
            <!-- LEFT: Details -->
            <div class="col-lg-8">
                <div data-aos="fade-right">

                    {% set property_type = node.field_property_type.entity %}
                    {% set property_parent = property_type.parent.entity ?? null %}
                    {% set ownership = node.field_ownership_type.value %}
                    {% set purpose = node.field_purpose_of.entity %}

                    <div class="prop-id-bar">
                        <div class="prop-id">
                            Property ID:
                            <strong>{{ node.field_property_id_number.value }}</strong>
                        </div>

                        <div class="prop-posted">
                            <i class="fa fa-calendar"></i>
                            Posted on {{ node.getCreatedTime|date('d M Y') }}
                        </div>
                    </div>

                    <h1 class="prop-title">{{ node.label }}</h1>

                    <div class="prop-location">
                        <i class="fa fa-map-marker-alt" style="color:var(--accent)"></i>

                        <span>

                            {% if node.field_locality.value %}
                            {{ node.field_locality.value }},
                            {% endif %}

                            {% if node.field_city.value %}
                            <a href="#">{{ node.field_city.value }}</a>,
                            {% endif %}

                            {% if node.field_state.value %}
                            <a href="#">{{ node.field_state.value }}</a>
                            {% endif %}

                            {% if node.field_pincode.value %}
                            — {{ node.field_pincode.value }}
                            {% endif %}

                        </span>
                    </div>

                    <div class="prop-tags">

                        {% if property_type %}
                        <span class="prop-tag">
                            <i class="fa fa-home me-1"></i>
                            {{ property_type.name.value }}
                        </span>
                        {% endif %}

                        {% if property_parent %}
                        <span class="prop-tag">
                            <i class="fa fa-building me-1"></i>
                            {{ property_parent.name.value }}
                        </span>
                        {% endif %}

                        {# East Facing (No field available yet) #}
                        <span class="prop-tag orange">
                            <i class="fa fa-compass me-1"></i>
                            East Facing
                        </span>

                        {% if node.field_floor_number.value %}
                        <span class="prop-tag">
                            <i class="fa fa-layer-group me-1"></i>
                            {{ node.field_floor_number.value }}
                        </span>
                        {% endif %}

                        {# RERA Registered (No field available yet) #}
                        <span class="prop-tag orange">
                            <i class="fa fa-certificate me-1"></i>
                            RERA Registered
                        </span>

                        {% if ownership %}
                        <span class="prop-tag">
                            <i class="fa fa-key me-1"></i>
                            {{ ownership }}
                        </span>
                        {% endif %}

                    </div>

                    <div class="prop-actions">
                        <button class="btn-action" id="likeBtn" onclick="toggleLike()">
                            <i class="fa fa-heart"></i> Save
                        </button>

                        <button class="btn-action" id="shareBtn" onclick="shareProperty()">
                            <i class="fa fa-share-nodes"></i> Share
                        </button>

                        <button class="btn-action" onclick="printPage()">
                            <i class="fa fa-print"></i> Print
                        </button>

                        <button class="btn-action"
                            onclick="showToast('Report submitted. We will review this listing.','fa-flag')">
                            <i class="fa fa-flag"></i> Report
                        </button>
                    </div>

                </div>

                <!-- QUICK STATS -->
                {% set property_parent = node.field_property_type.entity.parent.entity.name.value ?? '' %}

                <div class="quick-stats" data-aos="fade-up" data-aos-delay="100">

                    {# ================= Residential ================= #}
                    {% if property_parent == 'Residential Properties' %}

                    {% if node.field_bhk_type.value %}
                    <div class="qs-item">
                        <i class="fa fa-bed"></i>
                        <div class="qs-val">{{ node.field_bhk_type.value }}</div>
                        <div class="qs-label">BHK</div>
                    </div>
                    {% endif %}

                    {% if node.field_bathrooms.value %}
                    <div class="qs-item">
                        <i class="fa fa-bath"></i>
                        <div class="qs-val">{{ node.field_bathrooms.value }}</div>
                        <div class="qs-label">Bathrooms</div>
                    </div>
                    {% endif %}

                    {% if node.field_built_up_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-ruler-combined"></i>
                        <div class="qs-val">{{ node.field_built_up_area.value }}</div>
                        <div class="qs-label">Built-up Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_parking_capacity.value %}
                    <div class="qs-item">
                        <i class="fa fa-car"></i>
                        <div class="qs-val">{{ node.field_parking_capacity.value }}</div>
                        <div class="qs-label">Parking</div>
                    </div>
                    {% endif %}

                    {% if node.field_floor_number.value or node.field_total_floors.value %}
                    <div class="qs-item">
                        <i class="fa fa-layer-group"></i>
                        <div class="qs-val">{{ node.field_floor_number.value }} / {{ node.field_total_floors.value }}
                        </div>
                        <div class="qs-label">Floor</div>
                    </div>
                    {% endif %}

                    {# Facing field not available #}
                    <div class="qs-item">
                        <i class="fa fa-compass"></i>
                        <div class="qs-val">East</div>
                        <div class="qs-label">Facing</div>
                    </div>

                    {% if node.field_carpet_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-couch"></i>
                        <div class="qs-val">{{ node.field_carpet_area.value }}</div>
                        <div class="qs-label">Carpet Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_super_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-expand"></i>
                        <div class="qs-val">{{ node.field_super_area.value }}</div>
                        <div class="qs-label">Super Area</div>
                    </div>
                    {% endif %}

                    {# ================= Commercial ================= #}

                    {% elseif property_parent == 'Commercial Properties' %}

                    {% if node.field_built_up_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-ruler-combined"></i>
                        <div class="qs-val">{{ node.field_built_up_area.value }}</div>
                        <div class="qs-label">Built-up Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_loading_area_sq_ft.value %}
                    <div class="qs-item">
                        <i class="fa fa-truck-loading"></i>
                        <div class="qs-val">{{ node.field_loading_area_sq_ft.value }}</div>
                        <div class="qs-label">Loading Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_storage_area_sq_ft.value %}
                    <div class="qs-item">
                        <i class="fa fa-warehouse"></i>
                        <div class="qs-val">{{ node.field_storage_area_sq_ft.value }}</div>
                        <div class="qs-label">Storage Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_parking_capacity.value %}
                    <div class="qs-item">
                        <i class="fa fa-car"></i>
                        <div class="qs-val">{{ node.field_parking_capacity.value }}</div>
                        <div class="qs-label">Parking</div>
                    </div>
                    {% endif %}

                    {% if node.field_cm_floor_number.value or node.field_commercial_total_floors.value %}
                    <div class="qs-item">
                        <i class="fa fa-layer-group"></i>
                        <div class="qs-val">{{ node.field_cm_floor_number.value }} / {{
                            node.field_commercial_total_floors.value }}</div>
                        <div class="qs-label">Floor</div>
                    </div>
                    {% endif %}

                    {# ================= Agricultural ================= #}

                    {% elseif property_parent == 'Agricultural Properties' %}

                    {% if node.field_ag_land_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-ruler-combined"></i>
                        <div class="qs-val">{{ node.field_ag_land_area.value }} {{ node.field_ag_land_unit.value }}
                        </div>
                        <div class="qs-label">Land Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_ag_land_type.value %}
                    <div class="qs-item">
                        <i class="fa fa-seedling"></i>
                        <div class="qs-val">{{ node.field_ag_land_type.value }}</div>
                        <div class="qs-label">Land Type</div>
                    </div>
                    {% endif %}

                    {% if node.field_crop_type.value %}
                    <div class="qs-item">
                        <i class="fa fa-leaf"></i>
                        <div class="qs-val">{{ node.field_crop_type.value }}</div>
                        <div class="qs-label">Crop Type</div>
                    </div>
                    {% endif %}

                    {% if node.field_water_source.value %}
                    <div class="qs-item">
                        <i class="fa fa-tint"></i>
                        <div class="qs-val">{{ node.field_water_source.value }}</div>
                        <div class="qs-label">Water Source</div>
                    </div>
                    {% endif %}

                    {# ================= Land / Plot ================= #}

                    {% elseif property_parent == 'Land / Plot' %}

                    {% if node.field_total_area.value %}
                    <div class="qs-item">
                        <i class="fa fa-ruler-combined"></i>
                        <div class="qs-val">{{ node.field_total_area.value }}</div>
                        <div class="qs-label">Total Area</div>
                    </div>
                    {% endif %}

                    {% if node.field_length_ft.value %}
                    <div class="qs-item">
                        <i class="fa fa-arrows-alt-h"></i>
                        <div class="qs-val">{{ node.field_length_ft.value }}</div>
                        <div class="qs-label">Length (Ft)</div>
                    </div>
                    {% endif %}

                    {% if node.field_width_ft.value %}
                    <div class="qs-item">
                        <i class="fa fa-arrows-alt-v"></i>
                        <div class="qs-val">{{ node.field_width_ft.value }}</div>
                        <div class="qs-label">Width (Ft)</div>
                    </div>
                    {% endif %}

                    {% if node.field_road_width_ft.value %}
                    <div class="qs-item">
                        <i class="fa fa-road"></i>
                        <div class="qs-val">{{ node.field_road_width_ft.value }}</div>
                        <div class="qs-label">Road Width</div>
                    </div>
                    {% endif %}

                    {% endif %}

                </div>

                <!-- DETAIL TABS -->
                <div data-aos="fade-up" data-aos-delay="150">
                    <div class="detail-tabs">
                        <button class="detail-tab active" onclick="switchTab('overview', this)"><i
                                class="fa fa-info-circle"></i> Overview</button>
                        <button class="detail-tab" onclick="switchTab('specs', this)"><i class="fa fa-list-check"></i>
                            Specifications</button>
                        <button class="detail-tab" onclick="switchTab('amenities', this)"><i class="fa fa-star"></i>
                            Amenities</button>
                        <button class="detail-tab" onclick="switchTab('location', this)"><i
                                class="fa fa-map-location-dot"></i> Location</button>
                        <button class="detail-tab" onclick="switchTab('documents', this)"><i
                                class="fa fa-file-shield"></i> Documents</button>
                    </div>

                    <!-- TAB: OVERVIEW -->
                    <div class="tab-panel active" id="tab-overview">
                        <div class="info-card">
                            <div class="info-card-title"><i class="fa fa-align-left"></i> Property Description</div>

                            {% if node.body.value %}
                            <div class="desc-text">
                                {{ node.body.value|raw }}
                            </div>
                            {% endif %}

                            {% if node.field_property_highlights.value %}
                            <div class="highlight-box">
                                <h6><i class="fa fa-bolt me-1"></i> Property Highlights</h6>

                                <ul class="highlight-list">
                                    {% for highlight in node.field_property_highlights.value|split(',') %}
                                    {% if highlight|trim %}
                                    <li>
                                        <i class="fa fa-check"></i>
                                        {{ highlight|trim }}
                                    </li>
                                    {% endif %}
                                    {% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </div>

                        <!-- RENT SECTION (Hidden for Sale - shown as example structure) -->
                        <!-- For rent properties, monthly rent & security deposit would appear here -->

                        {% if node.field_purpose_of.entity and node.field_purpose_of.entity.name.value|lower == 'rent'
                        %}
                        <div class="info-card">
                            <div class="info-card-title">
                                <i class="fa fa-money-bill-wave"></i> Rental Details
                            </div>

                            <div class="spec-grid">

                                {% if node.field_monthly_rent.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Monthly Rent</span>
                                    <span class="spec-value">₹{{ node.field_monthly_rent.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_security_deposit.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Security Deposit</span>
                                    <span class="spec-value">₹{{ node.field_security_deposit.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_maintenance_charges.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Maintenance Charges</span>
                                    <span class="spec-value">₹{{ node.field_maintenance_charges.value }}</span>
                                </div>
                                {% endif %}

                            </div>
                        </div>
                        {% endif %}

                        <!-- SIZE OVERVIEW -->
                        <div class="info-card">
                            <div class="info-card-title">
                                <i class="fa fa-ruler-combined"></i> Area Details
                            </div>

                            <div class="spec-grid">

                                {% if node.field_total_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Total Area</span>
                                    <span class="spec-value">{{ node.field_total_area.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_carpet_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Carpet Area</span>
                                    <span class="spec-value">
                                        {{ node.field_carpet_area.value }}
                                    </span>
                                </div>
                                {% endif %}

                                {% if node.field_built_up_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Built-up Area</span>
                                    <span class="spec-value">
                                        {{ node.field_built_up_area.value }}
                                    </span>
                                </div>
                                {% endif %}

                                {% if node.field_super_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Super Area</span>
                                    <span class="spec-value">
                                        {{ node.field_super_area.value }}
                                    </span>
                                </div>
                                {% endif %}

                                {% if node.field_ag_land_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Agricultural Land Area</span>
                                    <span class="spec-value">
                                        {{ node.field_ag_land_area.value }}
                                    </span>
                                </div>
                                {% endif %}

                                {% if node.field_area_unit.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Area Unit</span>
                                    <span class="spec-value">
                                        {{ node.field_area_unit.value }}
                                    </span>
                                </div>
                                {% endif %}

                                {% if node.field_expected_price.value and node.field_total_area.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Price</span>
                                    <span class="spec-value" style="color:var(--accent)">
                                        ₹{{ node.field_expected_price.value }}
                                    </span>
                                </div>
                                {% endif %}

                            </div>
                        </div>
                    </div>

                    <!-- TAB: SPECIFICATIONS -->
                    <div class="tab-panel" id="tab-specs">
                        {% set property_parent = node.field_property_type.entity.parent.entity.name.value ?? '' %}

                        {% if property_parent == 'Residential Properties' %}

                        <div class="info-card">
                            <div class="info-card-title"><i class="fa fa-bed"></i> Residential Details</div>

                            <div class="spec-grid">

                                {% if node.field_bhk_type.value %}
                                <div class="spec-item">
                                    <span class="spec-label">BHK Type</span>
                                    <span class="spec-value">{{ node.field_bhk_type.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_bedrooms.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Bedrooms</span>
                                    <span class="spec-value">{{ node.field_bedrooms.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_bathrooms.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Bathrooms</span>
                                    <span class="spec-value">{{ node.field_bathrooms.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_balconies.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Balconies</span>
                                    <span class="spec-value">{{ node.field_balconies.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_kitchen.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Kitchen</span>
                                    <span class="spec-value">{{ node.field_kitchen.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_drawing_room.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Drawing Room</span>
                                    <span class="spec-value">{{ node.field_drawing_room.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_dining_room.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Dining Room</span>
                                    <span class="spec-value">{{ node.field_dining_room.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_store_room.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Store Room</span>
                                    <span class="spec-value">{{ node.field_store_room.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_pooja_room.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Pooja Room</span>
                                    <span class="spec-value">{{ node.field_pooja_room.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_study_room.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Study Room</span>
                                    <span class="spec-value">{{ node.field_study_room.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_floor_number.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Floor Number</span>
                                    <span class="spec-value">{{ node.field_floor_number.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_total_floors.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Total Floors</span>
                                    <span class="spec-value">{{ node.field_total_floors.value }}</span>
                                </div>
                                {% endif %}

                                {# Facing field not available in current content type #}

                                {% if node.field_corner_property.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Corner Property</span>
                                    <span class="spec-value">{{ node.field_corner_property.value }}</span>
                                </div>
                                {% endif %}

                            </div>
                        </div>

                        {% endif %}

                        {% if property_parent == 'Commercial Properties' or property_parent == 'Industrial Properties'
                        %}

                        <div class="info-card">
                            <div class="info-card-title">
                                <i class="fa fa-building"></i> Commercial Details
                            </div>

                            <div class="spec-grid">

                                {% if node.field_cm_floor_number.value %}
                                <div class="spec-item">
                                    <span class="spec-label">Floor Number</span>
                                    <span class="spec-value">{{ node.field_cm_floor_number.value }}</span>
                                </div>
                                {% endif %}

                                {% if node.field_commercial_total_floors.value %}
                                <div class="spec-item">
