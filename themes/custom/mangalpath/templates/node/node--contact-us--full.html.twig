<button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})"><i class="fa fa-arrow-up"></i></button>

<script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
<script>
    AOS.init({ duration: 700, once: true, offset: 60 });

    // ===== FORM SUBMISSION =====
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const name = document.getElementById('cName').value.trim();
        const phone = document.getElementById('cPhone').value.trim();
        const email = document.getElementById('cEmail').value.trim();
        const service = document.getElementById('cService').value;
        const message = document.getElementById('cMessage').value.trim();
        const consent = document.getElementById('cConsent').checked;

        // Validation
        let isValid = true;
        const fields = [
            { el: document.getElementById('cName'), val: name },
            { el: document.getElementById('cPhone'), val: phone },
            { el: document.getElementById('cEmail'), val: email },
            { el: document.getElementById('cService'), val: service },
            { el: document.getElementById('cMessage'), val: message }
        ];

        fields.forEach(f => {
            if (!f.val) {
                f.el.style.borderColor = '#ef4444';
                f.el.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.1)';
                isValid = false;
            } else {
                f.el.style.borderColor = '';
                f.el.style.boxShadow = '';
            }
        });

        // Email format check
        if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            document.getElementById('cEmail').style.borderColor = '#ef4444';
            document.getElementById('cEmail').style.boxShadow = '0 0 0 3px rgba(239,68,68,0.1)';
            isValid = false;
        }

        // Phone format check
        if (phone && !/^[0-9+\-\s]{10,15}$/.test(phone.replace(/\s/g,''))) {
            document.getElementById('cPhone').style.borderColor = '#ef4444';
            document.getElementById('cPhone').style.boxShadow = '0 0 0 3px rgba(239,68,68,0.1)';
            isValid = false;
        }

        if (!consent) {
            showToast('Please agree to be contacted before submitting.', 'fa-exclamation-triangle');
            return;
        }

        if (!isValid) {
            showToast('Please fill all required fields correctly.', 'fa-exclamation-triangle');
            // Focus first invalid
            for (const f of fields) {
                if (!f.val) { f.el.focus(); break; }
            }
            return;
        }

        // Simulate submit
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Sending...';

        setTimeout(() => {
            document.getElementById('contactForm').style.display = 'none';
            document.querySelector('.contact-form .sub').style.display = 'none';
            document.getElementById('formSuccess').classList.add('show');
            showToast('Message sent successfully!', 'fa-check-circle');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-paper-plane me-2"></i>Send Message';
        }, 1500);
    });

    // Reset form
    function resetForm() {
        document.getElementById('contactForm').reset();
        document.getElementById('contactForm').style.display = '';
        document.querySelector('.contact-form .sub').style.display = '';
        document.getElementById('formSuccess').classList.remove('show');
        // Clear any error styles
        document.querySelectorAll('.contact-form .form-control, .contact-form .form-select').forEach(el => {
            el.style.borderColor = '';
            el.style.boxShadow = '';
        });
    }

    // Clear error on input
    document.querySelectorAll('.contact-form .form-control, .contact-form .form-select').forEach(el => {
        el.addEventListener('input', function() {
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });
        el.addEventListener('change', function() {
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });
    });

    // ===== FAQ =====
    function toggleFaq(btn) {
        const item = btn.closest('.faq-item');
        const wasOpen = item.classList.contains('open');
        // Close all
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        // Toggle clicked
        if (!wasOpen) item.classList.add('open');
    }

    // ===== TOAST =====
    function showToast(msg, icon) {
        const toast = document.getElementById('toastMsg');
        document.getElementById('toastText').textContent = msg;
        toast.querySelector('i').className = 'fa ' + (icon || 'fa-check-circle');
        toast.querySelector('i').style.color = icon === 'fa-exclamation-triangle' ? '#f59e0b' : 'var(--green)';
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3500);
    }

    // ===== BACK TO TOP =====
    window.addEventListener('scroll', function() {
        document.getElementById('backToTop').classList.toggle('visible', window.scrollY > 400);
    });
</script>
