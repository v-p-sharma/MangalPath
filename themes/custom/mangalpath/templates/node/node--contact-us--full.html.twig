
    <style>
        :root {
            --primary: #1a3c6e;
            --primary-dark: #0f2548;
            --accent: #f5821f;
            --accent-dark: #d96b10;
            --light-bg: #f4f7fc;
            --text: #1e2d40;
            --text-muted: #5a6a7a;
            --white: #ffffff;
            --border: #e0e8f4;
            --green: #16a34a;
            --card-shadow: 0 4px 24px rgba(26,60,110,0.09);
            --radius: 14px;
        }
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:'Nunito',sans-serif;color:var(--text);background:var(--light-bg);overflow-x:hidden;}
        ::-webkit-scrollbar{width:6px;}
        ::-webkit-scrollbar-track{background:#f1f1f1;}
        ::-webkit-scrollbar-thumb{background:var(--primary);border-radius:4px;}

        /* ===== BREADCRUMB ===== */
        .breadcrumb-bar{background:var(--white);border-bottom:1px solid var(--border);padding:12px 0;}
        .breadcrumb-bar .breadcrumb{margin:0;font-size:13px;font-weight:600;}
        .breadcrumb-bar .breadcrumb a{color:var(--text-muted);text-decoration:none;transition:color .2s;}
        .breadcrumb-bar .breadcrumb a:hover{color:var(--primary);}
        .breadcrumb-bar .breadcrumb .active{color:var(--primary);font-weight:700;}
        .breadcrumb-bar .breadcrumb-item+.breadcrumb-item::before{color:var(--text-muted);}

        /* ===== PAGE HEADER ===== */
        .page-header{background:linear-gradient(135deg,#e8f0fc 0%,#f0f7ff 50%,#fef3e8 100%);padding:50px 0 40px;position:relative;overflow:hidden;text-align:center;}
        .page-header::before{content:'';position:absolute;top:-60px;right:-60px;width:400px;height:400px;background:radial-gradient(circle,rgba(245,130,31,0.08) 0%,transparent 70%);border-radius:50%;}
        .page-header::after{content:'';position:absolute;bottom:-40px;left:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(26,60,110,0.06) 0%,transparent 70%);border-radius:50%;}
        .page-header h1{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,42px);font-weight:800;color:var(--primary-dark);margin-bottom:8px;}
        .page-header h1 span{color:var(--accent);}
        .page-header p{color:var(--text-muted);font-size:15px;max-width:560px;margin:0 auto;line-height:1.7;}

        /* ===== QUICK CONTACT BAR ===== */
        .quick-contact-bar{background:var(--white);border-bottom:1px solid var(--border);padding:0;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(26,60,110,0.06);}
        .qcb-inner{display:flex;justify-content:center;gap:0;flex-wrap:wrap;}
        .qcb-item{display:flex;align-items:center;gap:10px;padding:16px 28px;border-right:1px solid var(--border);transition:background .2s;cursor:default;text-decoration:none;color:var(--text);}
        .qcb-item:last-child{border-right:none;}
        .qcb-item:hover{background:var(--light-bg);}
        .qcb-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
        .qcb-icon.blue{background:#e3edf8;color:var(--primary);}
        .qcb-icon.green{background:#e8f5e9;color:var(--green);}
        .qcb-icon.orange{background:#fff3e0;color:var(--accent);}
        .qcb-icon.purple{background:#f0ebff;color:#6d28d9;}
        .qcb-text .qcb-label{font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;}
        .qcb-text .qcb-value{font-size:14px;font-weight:800;color:var(--primary-dark);}
        .qcb-text a{color:var(--primary-dark);text-decoration:none;font-weight:800;font-size:14px;}
        .qcb-text a:hover{color:var(--accent);}
        @media(max-width:767px){
            .qcb-item{padding:12px 16px;border-right:none;border-bottom:1px solid var(--border);flex:1 1 50%;min-width:0;}
            .qcb-inner{justify-content:center;}
        }

        /* ===== CONTACT CARD (from home page) ===== */
        .contact-section{padding:60px 0;}
        .contact-card{background:var(--white);border-radius:var(--radius);box-shadow:0 8px 40px rgba(26,60,110,0.10);overflow:hidden;}
        .contact-info{background:linear-gradient(160deg,var(--primary-dark) 0%,#1a4a8a 100%);padding:40px 36px;color:white;height:100%;position:relative;overflow:hidden;}
        .contact-info::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:rgba(255,255,255,0.04);border-radius:50%;}
        .contact-info::after{content:'';position:absolute;bottom:-60px;left:-30px;width:120px;height:120px;background:rgba(255,255,255,0.03);border-radius:50%;}
        .contact-info h3{font-size:24px;font-weight:800;margin-bottom:6px;position:relative;}
        .contact-info>.ci-desc{opacity:.75;font-size:14px;line-height:1.7;margin-bottom:30px;position:relative;}
        .ci-item{display:flex;gap:14px;margin-bottom:22px;align-items:flex-start;position:relative;}
        .ci-icon{width:42px;height:42px;border-radius:10px;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;transition:all .2s;}
        .ci-item:hover .ci-icon{background:var(--accent);transform:translateY(-2px);}
        .ci-item h6{font-size:12px;font-weight:800;margin-bottom:2px;opacity:.6;letter-spacing:.5px;text-transform:uppercase;}
        .ci-item p{font-size:14px;font-weight:600;margin:0;opacity:.95;line-height:1.5;}
        .ci-item a{color:white;text-decoration:none;opacity:.95;font-weight:600;font-size:14px;transition:opacity .2s;}
        .ci-item a:hover{opacity:1;text-decoration:underline;}
        .social-links{display:flex;gap:10px;margin-top:30px;position:relative;}
        .social-link{width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;color:white;font-size:15px;transition:all .2s;text-decoration:none;}
        .social-link:hover{background:var(--accent);color:white;transform:translateY(-3px);}
        .ci-working-hours{margin-top:28px;padding-top:22px;border-top:1px solid rgba(255,255,255,0.12);position:relative;}
        .ci-working-hours h6{font-size:13px;font-weight:800;margin-bottom:10px;opacity:.85;display:flex;align-items:center;gap:6px;}
        .wh-row{display:flex;justify-content:space-between;padding:5px 0;font-size:13px;font-weight:600;opacity:.8;}
        .wh-row .wh-day{opacity:.7;}
        .wh-row.closed{opacity:.5;text-decoration:line-through;}

        .contact-form{padding:40px 36px;}
        .contact-form h3{font-size:22px;font-weight:800;color:var(--primary-dark);margin-bottom:4px;}
        .contact-form .sub{font-size:13.5px;color:var(--text-muted);margin-bottom:24px;}
        .form-label{font-size:13px;font-weight:700;color:var(--text);margin-bottom:5px;}
        .form-label .required{color:#ef4444;}
        .form-control,.form-select{border:1.5px solid var(--border);border-radius:8px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;color:var(--text);padding:11px 14px;transition:all .2s;background:var(--white);}
        .form-control:focus,.form-select:focus{border-color:var(--primary);box-shadow:0 0 0 3px rgba(26,60,110,0.08);outline:none;}
        .form-control::placeholder{color:#94a3b8;font-weight:500;}
        .form-check{padding:0;margin:0;}
        .form-check-input{width:18px;height:18px;border:1.5px solid var(--border);border-radius:4px;cursor:pointer;margin-top:2px;}
        .form-check-input:checked{background-color:var(--primary);border-color:var(--primary);}
        .form-check-label{font-size:13px;font-weight:600;color:var(--text-muted);margin-left:6px;cursor:pointer;}
        .btn-submit{background:linear-gradient(135deg,var(--accent),var(--accent-dark));color:white;border:none;font-weight:800;font-size:15px;padding:14px 30px;border-radius:10px;width:100%;box-shadow:0 4px 16px rgba(245,130,31,0.35);transition:all .2s;cursor:pointer;font-family:'Nunito',sans-serif;}
        .btn-submit:hover{transform:translateY(-2px);box-shadow:0 6px 22px rgba(245,130,31,0.45);color:white;}
        .btn-submit:disabled{opacity:.6;cursor:not-allowed;transform:none;}
        .form-success{display:none;text-align:center;padding:40px 20px;}
        .form-success.show{display:block;}
        .form-success i{font-size:60px;color:var(--green);margin-bottom:16px;}
        .form-success h4{font-size:22px;font-weight:800;color:var(--primary-dark);margin-bottom:8px;}
        .form-success p{font-size:14px;color:var(--text-muted);line-height:1.7;margin-bottom:20px;}

        /* ===== MAP ===== */
        .map-section{padding:0 0 60px;}
        .map-card{background:var(--white);border-radius:var(--radius);overflow:hidden;box-shadow:var(--card-shadow);border:1.5px solid var(--border);}
        .map-placeholder{width:100%;height:350px;background:var(--light-bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;border-bottom:1px solid var(--border);}
        .map-placeholder i{font-size:48px;color:var(--primary);opacity:.2;}
        .map-placeholder p{font-size:14px;color:var(--text-muted);font-weight:600;}
        .map-placeholder span{font-size:12px;color:var(--text-muted);font-weight:500;}
        .map-info-bar{padding:20px 28px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
        .map-address{display:flex;align-items:flex-start;gap:12px;}
        .map-address i{color:var(--accent);font-size:18px;margin-top:2px;}
        .map-address .addr-text{font-size:14px;font-weight:700;color:var(--primary-dark);line-height:1.5;}
        .map-address .addr-sub{font-size:12.5px;color:var(--text-muted);font-weight:600;}
        .btn-get-direction{padding:10px 20px;border-radius:9px;border:2px solid var(--primary);background:var(--white);color:var(--primary);font-weight:800;font-size:13px;display:inline-flex;align-items:center;gap:7px;transition:all .2s;text-decoration:none;cursor:pointer;font-family:'Nunito',sans-serif;}
        .btn-get-direction:hover{background:var(--primary);color:white;transform:translateY(-1px);}

        /* ===== FAQ ===== */
        .faq-section{padding:0 0 80px;}
        .faq-card{background:var(--white);border-radius:var(--radius);border:1.5px solid var(--border);box-shadow:var(--card-shadow);overflow:hidden;}
        .faq-item{border-bottom:1px solid var(--border);}
        .faq-item:last-child{border-bottom:none;}
        .faq-question{width:100%;padding:18px 24px;background:none;border:none;text-align:left;font-size:14.5px;font-weight:700;color:var(--primary-dark);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px;transition:background .2s;font-family:'Nunito',sans-serif;}
        .faq-question:hover{background:var(--light-bg);}
        .faq-question .faq-q-icon{width:28px;height:28px;border-radius:7px;background:var(--light-bg);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--primary);flex-shrink:0;transition:all .2s;}
        .faq-item.open .faq-question{background:var(--light-bg);}
        .faq-item.open .faq-q-icon{background:var(--accent);color:white;transform:rotate(180deg);}
        .faq-answer{max-height:0;overflow:hidden;transition:max-height .35s ease,padding .35s ease;}
        .faq-item.open .faq-answer{max-height:300px;}
        .faq-answer-inner{padding:0 24px 20px;font-size:13.5px;color:var(--text-muted);line-height:1.8;}

        /* ===== SECTION HEADERS ===== */
        .section-badge{display:inline-block;background:rgba(245,130,31,0.1);color:var(--accent);font-size:12px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:5px 14px;border-radius:100px;margin-bottom:10px;}
        .section-title{font-family:'Playfair Display',serif;font-size:clamp(24px,3.5vw,38px);font-weight:800;color:var(--primary-dark);margin-bottom:10px;}
        .section-title span{color:var(--accent);}
        .section-line{width:50px;height:4px;background:linear-gradient(90deg,var(--accent),var(--primary));border-radius:2px;margin:12px 0 0;}
        .section-line.center{margin:12px auto 0;}
        .section-sub{color:var(--text-muted);font-size:15px;max-width:560px;line-height:1.7;}

        /* ===== TOAST ===== */
        .toast-msg{position:fixed;top:20px;right:20px;background:var(--primary-dark);color:white;padding:14px 24px;border-radius:10px;font-size:14px;font-weight:700;z-index:4000;transform:translateX(120%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;align-items:center;gap:10px;box-shadow:0 8px 30px rgba(0,0,0,0.25);}
        .toast-msg.show{transform:translateX(0);}
        .toast-msg i{font-size:18px;}

        /* ===== FLOATING ===== */
        #backToTop{position:fixed;bottom:24px;right:24px;z-index:9999;width:44px;height:44px;border-radius:10px;background:var(--primary);color:white;border:none;font-size:17px;box-shadow:0 4px 14px rgba(26,60,110,0.35);opacity:0;pointer-events:none;transition:all .3s;cursor:pointer;}
        #backToTop.visible{opacity:1;pointer-events:auto;}
        #backToTop:hover{background:var(--accent);transform:translateY(-2px);}
        .wa-float{position:fixed;bottom:24px;left:24px;z-index:9999;width:52px;height:52px;border-radius:50%;background:#25d366;color:white;display:flex;align-items:center;justify-content:center;font-size:26px;box-shadow:0 4px 20px rgba(37,211,102,0.45);text-decoration:none;animation:waPulse 2.5s infinite;}
        @keyframes waPulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.45);}50%{box-shadow:0 4px 32px rgba(37,211,102,0.65);}}

        /* ===== RESPONSIVE ===== */
        @media(max-width:991px){
            .contact-info{padding:36px 28px;}
            .contact-form{padding:36px 28px;}
        }
        @media(max-width:767px){
            .contact-section{padding:40px 0;}
            .contact-info{padding:30px 22px;}
            .contact-form{padding:30px 22px;}
            .map-placeholder{height:250px;}
            .faq-section{padding:0 0 60px;}
        }
    </style>

