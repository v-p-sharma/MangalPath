{#
/**
 * @file
 * Default theme implementation for views to display rows in a grid.
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapping element.
 * - title: The title of this group of rows.
 * - view: The view object.
 * - rows: The rendered view results.
 * - options: The view plugin style options.
 *   - row_class_default: A flag indicating whether default classes should be
 *     used on rows.
 *   - col_class_default: A flag indicating whether default classes should be
 *     used on columns.
 * - items: A list of grid items. Each item contains a list of rows or columns.
 *   The order in what comes first (row or column) depends on which alignment
 *   type is chosen (horizontal or vertical).
 *   - attributes: HTML attributes for each row or column.
 *   - content: A list of columns or rows. Each row or column contains:
 *     - attributes: HTML attributes for each row or column.
 *     - content: The row or column contents.
 *
 * @see template_preprocess_views_view_grid()
 *
 * @ingroup themeable
 */
#}

{%
  set classes = [
    'views-view-grid',
    options.alignment,
    'cols-' ~ options.columns,
    'clearfix',
  ]
%}
{% if options.row_class_default %}
  {%
    set row_classes = [
      'views-row',
      options.alignment == 'horizontal' ? 'clearfix',
    ]
  %}
{% endif %}
{% if options.col_class_default %}
  {%
    set col_classes = [
      'views-col',
      options.alignment == 'vertical' ? 'clearfix',
    ]
  %}
{% endif %}
{% if title %}
  <h3>{{ title }}</h3>
{% endif %}
<div{{ attributes.addClass(classes) }}>
  {% if options.alignment == 'horizontal' %}
    {% for row in items %}
      <div{{ row.attributes.addClass(row_classes, options.row_class_default ? 'row-' ~ loop.index) }}>
        {% for column in row.content %}
          <div{{ column.attributes.addClass(col_classes, options.col_class_default ? 'col-' ~ loop.index) }}>
         
           <div class="prop-card">
          <div class="prop-img-wrap">
            <img style= "width:100%" src="{{ file_url(column.content['#row']._entity.field_featured_image[0].entity.uri[0].value)}}" class="prop-img" alt="Villa">
            <span class="prop-badge">FOR {{column.content['#row']._entity.field_purpose_of[0].entity.name[0].value}}</span>
            <span class="price-tag">₹ {{column.content['#row']._entity.field_expected_price[0].value}}</span>
          </div>
          <div class="prop-body">
            <h3 class="prop-title">{{ column.content['#row']._entity.title[0].value }}</h3>
            <div class="prop-loc"><i class="fa fa-map-marker-alt me-1"></i> {{column.content['#row']._entity.field_city[0].value}}</div>
            {%if column.content['#row']._entity.field_property_type.entity.parent[0].entity.name[0].value =="Residential Properties" %}
            <div class="prop-features">
              <span><i class="fa fa-bed"></i>{{column.content['#row']._entity.field_bhk_type[0].value}}</span>
              <span><i class="fa fa-bath"></i> {{column.content['#row']._entity.field_bathrooms[0].value}}</span>
              <span><i class="fa fa-ruler-combined"></i> {{column.content['#row']._entity.field_total_area[0].value}} {{column.content['#row']._entity.field_area_unit[0].value}}</span>
            </div>
            {% endif %}
            {%if column.content['#row']._entity.field_property_type.entity.parent[0].entity.name[0].value =="Commercial Properties" or column.content['#row']._entity.field_property_type.entity.parent[0].entity.name[0].value =="Industrial Properties" %}
            <div class="prop-features">
              <span><i class="fa fa-bed"></i> {{column.content['#row']._entity.field_property_use[0].value}}</span>
              <span><i class="fa fa-bath"></i> {{column.content['#row']._entity.field_parking_capacity[0].value}}</span>
              <span><i class="fa fa-ruler-combined"></i> {{column.content['#row']._entity.field_loading_area_sq_ft[0].value}} Sqft</span>
            </div>
            {% endif %}
            {% if
        column.content['#row']._entity.field_property_type.entity.parent[0].entity.name[0].value == 'Agricultural Properties'
        or
        column.content['#row']._entity.field_property_type.entity.parent[0].entity.name[0].value == 'Land/Plot'
        %}
          <div class="prop-features">
              <span><i class="fa fa-tree"></i> {{column.content['#row']._entity.field_ag_land_type[0].value}}</span>
              <span><i class="fa fa-expand"></i>{{column.content['#row']._entity.field_ag_land_area[0].value}} {{column.content['#row']._entity.field_ag_land_unit[0].value}} 5 Bigha</span>
              <span><i class="fa fa-road"></i>{{column.content['#row']._entity.field_water_source[0].value}}</span>
              <span><i class="fa fa-road"></i>{{column.content['#row']._entity.field_road_access[0].value}}</span>
            </div>
            {% endif %}
            <div class="prop-btns">
              
              <a href="{{ path('entity.node.canonical', {'node': column.content['#row'].nid}) }}" class="btn-prop-outline">View Details</a>
              <a href="#enquiry-form" class="btn-prop-fill" onclick="prefillForm('MP-PROP-001')">Enquire Now</a>
            </div>
          </div>
        </div>



          </div>
        {% endfor %}
      </div>
    {% endfor %}
  {% else %}
    {% for column in items %}
      <div{{ column.attributes.addClass(col_classes, options.col_class_default ? 'col-' ~ loop.index) }}>
        {% for row in column.content %}
          <div{{ row.attributes.addClass(row_classes, options.row_class_default ? 'row-' ~ loop.index) }}>
            {{- row.content -}}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  {% endif %}
</div>
