<div class="container-fluid py-4">

    <div class="card shadow-sm">

        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                Vehicle Listing
            </h4>
        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-bordered table-striped table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th width="70">#</th>
                            <th>Title</th>
                            <th>Purpose</th>
                            <th>Brand</th>
                            <th>Subscriptions</th>
                            <th>Created Date</th>
                            <th>Status</th>
                            <th width="120">Action</th>
                             {% if logged_in and ('administrator' in user.roles or 'admin' in user.roles) %}
                            <td>
                         <a href="#"
                        class="btn btn-sm btn-primary js-change-status"
                        data-node="{{ row.id }}"
                        data-status="{{ row.partner_statusId }}">
                        Change Status
                    </a>

                            </td>
                         {% endif %}
                        </tr>
                    </thead>

                    <tbody>

                        {% if rows %}

                        {% for row in rows %}

                        <tr>

                            <td>{{ loop.index }}</td>

                            <td>
                                {{ row.title }}
                            </td>

                            <td>
                                {{ row.purpose }}
                            </td>

                            <td>
                                {{ row.brand }}
                            </td>
                            <td>{{row.subscriptions}}</td>

                            <td>
                                {{ row.created }}
                            </td>

                            <td>

                                {% set status = row.partner_status|lower %}

                                {% if status == 'listed' %}
                                <span class="badge bg-success">
                                    {{ row.partner_status }}
                                </span>

                                {% elseif status == 'pending' %}
                                <span class="badge bg-warning text-dark">
                                    {{ row.partner_status }}
                                </span>

                                {% elseif status == 'rejected' %}
                                <span class="badge bg-danger">
                                    {{ row.partner_status }}
                                </span>

                                {% elseif status == 'sold' %}
                                <span class="badge bg-primary">
                                    {{ row.partner_status }}
                                </span>

                                {% elseif status == 'inactive' %}
                                <span class="badge bg-secondary">
                                    {{ row.partner_status }}
                                </span>

                                {% else %}
                                <span class="badge bg-light text-dark">
                                    {{ row.partner_status }}
                                </span>
                                {% endif %}

                            </td>

                            <td>
                                {{ row.action }}
                            </td>


                            {% if logged_in and ('administrator' in user.roles or 'admin' in user.roles) %}
                            <td>
                                <a href="#" class="btn btn-sm btn-primary js-change-status" data-node="{{ row.id }}"
                                    data-status="{{ row.partner_statusId }}">
                                    Change Status
                                </a>

                            </td>
                            {% endif %}

                        </tr>

                        {% endfor %}

                        {% else %}

                        <tr>
                            <td colspan="7" class="text-center py-4">
                                No vehicle found.
                            </td>
                        </tr>

                        {% endif %}

                    </tbody>

                </table>

            </div>

            <div class="mt-4 d-flex justify-content-center">
                {{ pager }}
            </div>

        </div>

    </div>

</div>