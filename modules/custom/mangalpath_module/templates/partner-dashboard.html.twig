                <div class="val text-primary">₹{{ property.revenue|number_format(0, '.', ',') }}</div>
              </div>
            </div>
            <div class="biz-actions">
              <a href="/add/new-property" class="btn btn-primary btn-sm"><i class="fa fa-plus"></i> Add Property</a>
              <a href="#" class="btn btn-outline btn-sm">Manage</a>
            </div>
          </div>
        </div>

        <!-- Rental -->
        <div class="business-card">
          <div class="business-header">
            <h3 class="text-primary"><i class="fa fa-van-shuttle text-green"></i> Rental Business</h3>
            <span class="badge badge-success">Growing</span>
          </div>
          <div class="business-body">
            <div class="biz-metrics">
              <div class="biz-metric">
                <div class="label">Available</div>
                <div class="val">{{vehicle.total_rent_vehicle}} Vehicles</div>
              </div>
              <div class="biz-metric">
                <div class="label">On Trip</div>
                <div class="val text-accent">04</div>
              </div>
              <div class="biz-metric">
                <div class="label">Trips Done</div>
                <div class="val">145</div>
              </div>
              <div class="biz-metric">
                <div class="label">Distance</div>
