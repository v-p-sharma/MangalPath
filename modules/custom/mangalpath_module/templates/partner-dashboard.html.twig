                </tr>
                <tr>
                  <td> 
                   <h6>Partner User</h6>
                  </td>
                  <td><a href="/dashboard/admin/partnerList" >More Details</a></td>
                  
                </tr>
               
              </tbody>
            </table>
          
            </div>
          {% endif %}
          </div>
        </div>

