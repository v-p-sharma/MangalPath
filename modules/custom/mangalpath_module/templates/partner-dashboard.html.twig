        </div>
        <!-- 8 -->
        <div class="stat-card">
          <div class="stat-header">
            <div class="stat-icon purple"><i class="fa fa-van-shuttle"></i></div>
          </div>
          <div class="stat-value">{{ vehicle.total_rent }}</div>
          <div class="stat-label">Rental Bookings</div>
        </div>
        <!-- 9 -->
        <div class="stat-card">
          <div class="stat-header">
            <div class="stat-icon green"><i class="fa fa-chart-line"></i></div>
          </div>
          <div class="stat-value">₹{{ revenue|number_format(0, '.', ',') }}</div>
          <div class="stat-label">Total Profit</div>
        </div>
      </section>

      <!-- PERFORMANCE ANALYTICS -->
      <section class="charts-row">
