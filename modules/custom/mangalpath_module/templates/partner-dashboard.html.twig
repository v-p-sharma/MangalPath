            </div>
            <div class="biz-actions">
              <a href="#" class="btn btn-primary btn-sm"><i class="fa fa-plus"></i> Add Vehicle</a>
              <a href="#" class="btn btn-outline btn-sm">Bookings</a>
            </div>
          </div>
        </div>

        <!-- Sales -->
        <div class="business-card">
          <div class="business-header">
            <h3 class="text-primary"><i class="fa fa-car-side text-primary"></i> Vehicle Sales</h3>
            <span class="badge badge-warning">Pending: 2</span>
          </div>
          <div class="business-body">
            <div class="biz-metrics">
              <div class="biz-metric">
                <div class="label">For Sale</div>
                <div class="val">{{vehicle.total_sell_vehicle}} Vehicles</div>
              </div>
              <div class="biz-metric">
                <div class="label">Sold</div>
                <div class="val text-green">{{vehicle.total_sell}}</div>
              </div>
              <div class="biz-metric">
                <div class="label">Pending Deals</div>
                <div class="val text-accent">{{vehicle.total_pending}}</div>
              </div>
              <div class="biz-metric">
                <div class="label">Sales Rev</div>
                <div class="val text-primary">{{vehicle.revenue}}</div>
              </div>
            </div>
            <div class="biz-actions">
              <a href="#" class="btn btn-primary btn-sm"><i class="fa fa-plus"></i> Add Car</a>
              <a href="#" class="btn btn-outline btn-sm">Buyer Req</a>
