            <a href="/add/new-property" class="btn-hero-action"><i class="fa fa-plus"></i> Add New Property</a>
            <a href="/add/new-vehicle" class="btn-hero-action"><i class="fa fa-van-shuttle"></i> Add Rental Vehicle</a>
            <a href="/add/new-vehicle" class="btn-hero-action"><i class="fa fa-car-side"></i> Add Vehicle For Sale</a>
          </div>
        </div>
      </section>

