{% set common = statistics.common %}
{% set property = statistics.property %}
{% set vehicle = statistics.vehicle %}
{% set revenue = common.total_revenue %}
 
     <main class="main-content">
    
    <!-- TOP HEADER -->
    <header class="top-header">
      <div class="flex items-center gap-4">
        <button class="toggle-btn" id="toggleSidebar"><i class="fa fa-bars"></i></button>
        <div>
          <h2 class="font-extrabold text-primary" style="font-size:20px; line-height:1">Dashboard</h2>
        </div>
      </div>
      
      <div class="header-right">
        <div class="user-profile">
          <div class="user-info text-right">
          
            <h4>{{user.account.name}}</h4>
            <span>{{user.roles[1]}}</span>
          </div>
          <img src="https://picsum.photos/seed/rajesh/100/100" alt="User" class="user-avatar">
        </div>
        <button class="icon-btn">
          <i class="fa fa-cog"></i>
        </button>
        <button class="icon-btn">
          <i class="fa fa-bell"></i>
          <span class="notification-dot"></span>
        </button>
      </div>
    </header>

    <div class="dashboard-container">
      
