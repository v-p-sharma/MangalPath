    </div>
  </main>

  <script>
  // Toggle Sidebar
  const toggleBtn = document.getElementById('toggleSidebar');
  const sidebar = document.getElementById('sidebar');
  const mainContent = document.querySelector('.main-content');

  toggleBtn.addEventListener('click', () => {
    sidebar.classList.toggle('active');
  });

  // Close sidebar when clicking outside on mobile
  document.addEventListener('click', (e) => {
    if (window.innerWidth <= 768) {
      if (!sidebar.contains(e.target) && !toggleBtn.contains(e.target)) {
        sidebar.classList.remove('active');
      }
    }
  });

  document.addEventListener("DOMContentLoaded", function () {

    //==========================
    // Revenue & Enquiries Chart
    //==========================
    const ctx1 = document.getElementById('revenueChart').getContext('2d');

    let gradientFill = ctx1.createLinearGradient(0, 0, 0, 400);
    gradientFill.addColorStop(0, 'rgba(26,60,110,.20)');
    gradientFill.addColorStop(1, 'rgba(26,60,110,0)');

    new Chart(ctx1, {
      type: 'bar',
      data: {
        labels: ['Dashboard'],
        datasets: [
          {
            type: 'line',
            label: 'Revenue (₹)',
            data: [
              {{ common.total_revenue|default(0) }}
            ],
            borderColor: '#1a3c6e',
            backgroundColor: gradientFill,
            borderWidth: 3,
            fill: true,
            tension: .4,
            pointRadius: 6,
            pointHoverRadius: 8,
            yAxisID: 'y'
          },
          {
            label: 'Enquiries',
            data: [
              {{ common.total_enquery|default(0) }}
            ],
            backgroundColor: '#16a34a',
            borderRadius: 6,
            barThickness: 80,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false
        },
        plugins: {
          legend: {
            position: 'top',
            labels: {
              usePointStyle: true,
              boxWidth: 8
            }
          }
        },
        scales: {
          x: {
            grid: {
              display: false
            }
          },
          y: {
            position: 'left',
            beginAtZero: true,
            ticks: {
              callback: function(value){
                return '₹' + Number(value).toLocaleString('en-IN');
              }
            }
          },
          y1: {
            position: 'right',
            beginAtZero: true,
            grid: {
              drawOnChartArea: false
            }
          }
        }
      }
    });


    //==========================
    // Performance Mix
    //==========================
    const ctx2 = document.getElementById('performanceChart').getContext('2d');

    new Chart(ctx2,{
      type:'doughnut',
      data:{
        labels:[
          'Property Sold',
          'Property Rent',
          'Vehicle Sold',
          'Vehicle Rent'
        ],
        datasets:[{
          data:[
            {{ property.total_sell|default(0) }},
            {{ property.total_rent|default(0) }},
            {{ vehicle.total_sell|default(0) }},
            {{ vehicle.total_rent|default(0) }}
          ],
          backgroundColor:[
            '#1a3c6e',
            '#16a34a',
            '#f5821f',
            '#e2e8f0'
          ],
          borderWidth:0,
          hoverOffset:8
        }]
      },
      options:{
        responsive:true,
        maintainAspectRatio:false,
        cutout:'70%',
        plugins:{
          legend:{
            position:'bottom',
            labels:{
              usePointStyle:true,
              padding:20
            }
          }
        }
      }
    });

  });
</script>